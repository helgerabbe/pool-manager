{
  "name": "LookupPhasen",
  "type": "object",
  "properties": {
    "bezeichnung": {
      "type": "string",
      "description": "Bezeichnung der Phase (z.B. 'Halbjahr 1 2025/26')"
    },
    "ist_aktiv": {
      "type": "boolean",
      "default": true,
      "description": "Ob diese Phase als aktuelle Planungsphase gilt"
    }
  },
  "required": [
    "bezeichnung"
  ]
}