{
  "name": "AllgemeineAufgabe",
  "type": "object",
  "properties": {
    "einheit_id": {
      "type": "string",
      "description": "FK zur Einheit"
    },
    "themenfeld_id": {
      "type": "string",
      "description": "FK zum Themenfeld (optional)"
    },
    "anforderungsebene": {
      "type": "string",
      "enum": ["1 - Basis", "2 - Transfer", "3 - Projekt"],
      "default": "1 - Basis",
      "description": "Anforderungsebene der Aufgabe"
    },
    "aufgabentyp_projekt": {
      "type": "string",
      "enum": ["Anwendungsaufgabe", "Projektaufgabe"],
      "description": "Typ der Aufgabe (nur bei anforderungsebene: '3 - Projekt')"
    },
    "titel": {
      "type": "string",
      "description": "Titel der Aufgabe (optional)"
    },
    "aufgabenstellung": {
      "type": "string",
      "description": "Aufgabenstellung als Text (erforderlich)"
    },
    "aufgaben_bild_url": {
      "type": "string",
      "description": "URL zum optionalen Aufgabenbild"
    },
    "schwierigkeitsgrad": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Schwierigkeitsgrad (1=leicht, 2=mittel, 3=schwer, null=keine Angabe)"
    },
    "ergebnis_form": {
      "type": "string",
      "enum": [
        "Fließtext / Essay",
        "Tabelle / Matrix",
        "Präsentation / Folien",
        "Schema / Konzept-Map / Zeichnung",
        "Stichpunktartige Übersicht",
        "Mischform / Offen"
      ],
      "description": "Erwartete Form des Ergebnisses"
    },
    "ergebnis_dateiformat": {
      "type": "string",
      "enum": [
        "Textdokument (Word/PDF)",
        "Bilddatei (JPG/PNG)",
        "Präsentationsdatei (PowerPoint/PDF)",
        "Offen / Beliebig"
      ],
      "description": "Erwartetes Dateiformat des Ergebnisses"
    },
    "materialien": {
      "type": "array",
      "description": "Array von Materialien/Ressourcen",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["pdf", "image", "book_ref", "free_text"]
          },
          "content": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      }
    },
    "erwartungshorizont": {
      "type": "string",
      "description": "Erwartungshorizont / Zielvorgaben für Ebene-3-Aufgaben (Anwendungs- und Projektaufgaben). Dient dem KI-Tutor als inhaltliche Leitplanke für die Lernbegleitung."
    },
    "musterloesung": {
      "type": "string",
      "description": "Musterl\u00f6sung / Erwartungshorizont als Rich-Text"
    },
    "prioritaete_lernziele": {
      "type": "array",
      "description": "Array von Lernziel-IDs mit hoher Priorität für diese Aufgabe",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "content_status": {
      "type": "string",
      "enum": ["draft", "approved"],
      "default": "draft",
      "description": "Pädagogischer Status: draft (in Bearbeitung) oder approved (freigegeben)"
    },
    "sync_status": {
      "type": "string",
      "enum": ["new", "pending", "synced", "modified", "to_delete"],
      "default": "new",
      "description": "Moodle-Sync-Status: new, pending, synced, modified, to_delete"
    },
    "last_synced_at": {
      "type": "string",
      "format": "date-time",
      "description": "Zeitstempel des letzten erfolgreichen Moodle-Exports (nullable)"
    }
  },
  "required": ["einheit_id", "aufgabenstellung"]
}